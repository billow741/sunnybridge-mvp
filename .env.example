# SunnyBridge MVP — Environment Variables
# Copy to .env and fill in actual values

# --- App ---
APP_ENV=development
APP_NAME=SunnyBridge MVP
DEBUG=true

# --- Supabase (REST API — primary, works on free plan) ---
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...   # Public key, safe in browser with RLS
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Secret key, bypasses RLS — NEVER expose publicly
SUPABASE_DB_PASSWORD=your-db-password  # For Management API / psql access

# --- PostgreSQL direct connect (optional — paid plan only) ---
# Free plan cannot use direct DB connection; use REST API instead
# If on paid plan: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=

# --- JWT (RS256) ---
# Dev mode auto-generates keys if missing. Production: generate manually.
# openssl genrsa -out keys/private.pem 2048
# openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ALGORITHM=RS256

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Tencent Cloud SMS ---
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Sentry (optional) ---
SENTRY_DSN=
